<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollBeranda"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/layoutBeranda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvJudulBeranda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Beranda Donasi"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0B4F8A"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSapaan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selamat datang, Donatur"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:id="@+id/cardSaldo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#EAF4FA"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvLabelSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo Donatur"
                android:textSize="14sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 10.000.000"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222222" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardKampanye"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvNamaKampanye"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Donasi Bencana Alam Sumatera"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0B4F8A" />

            <TextView
                android:id="@+id/tvTargetKampanye"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Target: Rp 50.000.000"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvDanaTerkumpul"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Terkumpul: Rp 10.000.000"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBuatKampanye"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Buat Kampanye"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLihatKampanye"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Lihat Kampanye"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnDonasi"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Donasi Sekarang"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnKeluar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Keluar" />
    </LinearLayout>
</ScrollView>